                                <td style="text-align: right;">{{this.virginAmount}}</td>
                                <td style="font-weight: 700;">Total Spend</td>
                                <td style="text-align: right;">{{this.totalSpend}}</td>
                            </tr>
                        </tbody>
                    </table>
                    {{#each this.suppliers}}
                    <div class="card-header" style="margin-top: 10px; border-bottom: 1px solid #fde68a; background: #fffbeb; color: #92400e;">
                        Supplier: {{this.supplierName}}
                    </div>
                    <table style="margin-bottom: 10px;">
                        <thead>
                            <tr>
                                <th>SKU Code</th>
                                <th>SKU Description</th>
                                <th>Component</th>
                                <th>Polymer</th>
                                <th>Recycled Polymer Used</th>
                                <th style="text-align: right;">Annual Purchase MT</th>
                                <th style="text-align: right;">Virgin Qty</th>
                                <th style="text-align: right;">Virgin Amount</th>
                                <th style="text-align: right;">Recycled Qty</th>
                                <th style="text-align: right;">Recycled Amount</th>
                                <th style="text-align: right;">Total Spend</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each this.rows}}
                            <tr>
                                <td>{{this.skuCode}}</td>
                                <td>{{this.skuDescription}}</td>
                                <td>{{this.componentName}}</td>
                                <td>{{this.polymerName}}</td>
                                <td>{{this.recycledPolymerUsed}}</td>
                                <td style="text-align: right;">{{this.annualPurchaseMt}}</td>
                                <td style="text-align: right;">{{this.virginQty}}</td>
                                <td style="text-align: right;">{{this.virginAmount}}</td>
                                <td style="text-align: right;">{{this.recycledQty}}</td>
                                <td style="text-align: right;">{{this.recycledAmount}}</td>
                                <td style="text-align: right;">{{this.totalSpend}}</td>
                            </tr>
                            {{/each}}
                            <tr style="background: #fde68a; font-weight: 800;">
                                <td colspan="5">Total</td>
                                <td style="text-align: right;">{{this.totals.annualPurchaseMt}}</td>
                                <td style="text-align: right;">{{this.totals.virginQty}}</td>
                                <td style="text-align: right;">{{this.totals.virginAmount}}</td>
                                <td style="text-align: right;">{{this.totals.recycledQty}}</td>
                                <td style="text-align: right;">{{this.totals.recycledAmount}}</td>
                                <td style="text-align: right;">{{this.totals.totalSpend}}</td>
                            </tr>
                        </tbody>
                    </table>
                    {{/each}}
                </div>
                {{/each}}
            {{else}}
            <div class="card" style="text-align: center;">No Category Wise Supplier Details Available</div>
            {{/if}}
        </div>
        {{/if}}

        <div class="footer" style="position: absolute; bottom: 20px;">
            <span>AnantTattva EPR Kavach System</span>
            <span>Detailed Analysis</span>
        </div>
    </div>
    {{/if}}

</body>
</html>
