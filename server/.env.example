NODE_ENV=production
PORT=8080
FRONTEND_URL=https://your-frontend.example.com

MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/eprkavach

SECRET_KEY_ACCESS_TOKEN=replace-with-a-random-secret-of-at-least-32-characters
SECRET_KEY_REFRESH_TOKEN=replace-with-a-random-secret-of-at-least-32-characters

MAIL_USER=mailer@example.com
MAIL_PASS=replace-with-mail-password-or-app-password
MAIL_FROM=no-reply@example.com
MAIL_SERVICE=gmail
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Optional but strongly recommended in production
REDIS_URL=redis://localhost:6379
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# Required if Firebase Admin integration is used
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
